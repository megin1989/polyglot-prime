    START WITH 1
    INCREMENT BY 1
    NO MINVALUE
    NO MAXVALUE
    CACHE 1;

CREATE SEQUENCE IF NOT EXISTS mco_audit.mco_error_types_error_type_id_seq
    START WITH 1
    INCREMENT BY 1
    NO MINVALUE
    NO MAXVALUE
    CACHE 1;

CREATE TABLE IF NOT EXISTS mco_audit.mco_error_types (
    error_type_guid uuid DEFAULT techbd_udi_ingress.uuid_generate_v4() NOT NULL,
    error_type_id bigint DEFAULT nextval('mco_audit.mco_error_types_error_type_id_seq'::regclass) NOT NULL,
    error_type_name character varying(255),
    error_type_description character varying(255),
    is_active bit(1),
    created_on_utc timestamp with time zone,
    updated_on_utc timestamp with time zone
);


CREATE SEQUENCE IF NOT EXISTS mco_audit.mco_record_batch_batch_id_seq
    START WITH 1
    INCREMENT BY 1
    NO MINVALUE
    NO MAXVALUE
    CACHE 1;

CREATE SEQUENCE IF NOT EXISTS mco_audit.mco_record_batch_details_batch_id_seq
    START WITH 1
    INCREMENT BY 1
    NO MINVALUE
    NO MAXVALUE
    CACHE 1;

CREATE TABLE IF NOT EXISTS mco_audit.mco_record_details (
    batch_details_guid uuid DEFAULT techbd_udi_ingress.uuid_generate_v4() NOT NULL,
    batch_details_id bigint DEFAULT nextval('mco_audit.mco_record_batch_details_batch_id_seq'::regclass) NOT NULL,
    current_file_name character varying(255),
    file_size_in_kb character varying(255),
    total_records bigint,
    processed_count bigint,
    errored_count bigint,
    qa_completed_time timestamp with time zone,
    sent_to_datalake_time timestamp with time zone,
    sent_to_mco_time timestamp with time zone,
    created_on_utc timestamp with time zone,
    updated_on_utc timestamp with time zone,
    is_active bit(1),
    status character varying(255),
    batch_id bigint,
    reporting_month character varying(255),
    mco_id bigint
);

CREATE SEQUENCE IF NOT EXISTS mco_audit.mco_record_error_logs_error_log_id_seq
    START WITH 1
