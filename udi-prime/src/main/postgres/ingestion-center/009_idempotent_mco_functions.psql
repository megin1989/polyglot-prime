COMMENT ON EXTENSION "uuid-ossp" IS 'generate universally unique identifiers (UUIDs)';

CREATE SEQUENCE IF NOT EXISTS mco_audit.mco_mco_id_seq
    START WITH 1
    INCREMENT BY 1
    NO MINVALUE
    NO MAXVALUE
    CACHE 1;

CREATE TABLE IF NOT EXISTS mco_audit.mco (
    mco_guid uuid DEFAULT techbd_udi_ingress.uuid_generate_v4() NOT NULL,
    mco_id bigint DEFAULT nextval('mco_audit.mco_mco_id_seq'::regclass) NOT NULL,
    mco_name character varying(255) NOT NULL,
    description character varying(255),
    created_on_utc timestamp with time zone,
    updated_on_utc timestamp with time zone,
    is_active bit(1),
    mco_code character varying(255) NOT NULL
);

CREATE SEQUENCE IF NOT EXISTS mco_audit.mco_error_code_error_code_id_seq
    START WITH 1
    INCREMENT BY 1
    NO MINVALUE
    NO MAXVALUE
    CACHE 1;


